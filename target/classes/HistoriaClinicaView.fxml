<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="consultorio.HistoriaClinicaController"
      spacing="10"
      alignment="CENTER"
      prefWidth="900"
      prefHeight="600">

    <Label fx:id="lblPaciente"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <TableView fx:id="tablaConsultas" prefHeight="500" prefWidth="850">
        <columns>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
            <TableColumn fx:id="colMotivo" text="Motivo" prefWidth="220"/>
            <TableColumn fx:id="colDiagnostico" text="Diagnóstico" prefWidth="220"/>
            <TableColumn fx:id="colTratamiento" text="Tratamiento" prefWidth="220"/>
        </columns>
    </TableView>

    <Button text="Volver" onAction="#onVolver"/>

</VBox>