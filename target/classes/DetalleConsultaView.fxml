<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="consultorio.DetalleConsultaController"
      spacing="12"
      alignment="TOP_CENTER"
      prefWidth="900"
      prefHeight="600">

    <Label text="Detalle de Consulta"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <Label fx:id="lblPaciente"/>

    <GridPane hgap="10" vgap="10">

        <Label text="Fecha:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="lblFecha" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Motivo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="lblMotivo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Diagnóstico:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="lblDiagnostico" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Tratamiento:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="lblTratamiento" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="lblObservaciones" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Próximo Control:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <Label fx:id="lblProximoControl" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Editar" onAction="#onEditar"/>
        <Button text="Volver" onAction="#onVolver"/>
    </HBox>

</VBox>