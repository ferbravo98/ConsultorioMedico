<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="consultorio.EstudiosController"
      spacing="10"
      alignment="CENTER"
      prefWidth="900"
      prefHeight="600">

    <Label fx:id="lblPaciente"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Nuevo estudio" onAction="#onNuevoEstudio"/>
        <Button text="Editar estudio" onAction="#onEditarEstudio"/>
        <Button text="Volver" onAction="#onVolver"/>
    </HBox>

    <TableView fx:id="tablaEstudios" prefWidth="850" prefHeight="500">
        <columns>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
            <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150"/>
            <TableColumn fx:id="colNombre" text="Estudio" prefWidth="220"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
            <TableColumn fx:id="colIndicacion" text="Indicación" prefWidth="250"/>
        </columns>
    </TableView>

</VBox>