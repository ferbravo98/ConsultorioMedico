<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="consultorio.EstudioFormController"
      spacing="12"
      alignment="TOP_CENTER">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="lblTitulo"
           text="Nuevo Estudio"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Label fx:id="lblPaciente"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Fecha:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dpFecha" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Tipo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbTipo" prefWidth="250" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Nombre del estudio:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNombre" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Estado:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cbEstado" prefWidth="250" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Indicación:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtIndicacion" prefRowCount="3" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Resultado / informe:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtResultado" prefRowCount="3" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Ruta archivo:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="txtRutaArchivo" promptText="Opcional" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Guardar" onAction="#onGuardar"/>
        <Button text="Volver" onAction="#onVolver"/>
    </HBox>

</VBox>